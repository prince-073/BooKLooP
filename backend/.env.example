PORT=5000

# SQLite database file (local to the backend folder).
# Example: file:./dev.db
DATABASE_URL="file:./dev.db"

JWT_SECRET="replace_me_with_a_long_random_secret"
JWT_EXPIRES_IN="7d"

# Optional: if set, only emails ending with these domains can register.
# Example: UNIVERISTY_EMAIL_DOMAINS="university.edu,cs.university.edu"
UNIVERSITY_EMAIL_DOMAINS=""

# Configure which frontend origin can call the API (CORS).
# Example: CORS_ORIGIN="http://localhost:3000"
CORS_ORIGIN="*"

# Optional: bcrypt salt rounds
BCRYPT_SALT_ROUNDS=10

# =============================
# OTP (Email One-Time Password)
# =============================

# Dev mode: OTP shown on screen instead of email. Set "false" for real email.
OTP_DEV_RETURN="true"

# OTP lifetime and rate limiting
OTP_EXPIRES_MINUTES=10
OTP_REQUEST_WINDOW_SECONDS=60
OTP_RATE_LIMIT_MAX=5

# ---------- SMTP (for real email OTP) ----------
# Free option: Brevo (brevo.com) - 300 emails/day free
# 1. Sign up at brevo.com
# 2. SMTP & API → SMTP → Create SMTP key
# 3. Use your Brevo login email as SMTP_USER
# 4. Use the SMTP key as SMTP_PASS
# 5. Set OTP_DEV_RETURN="false"
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Campus Book Exchange <no-reply@example.com>"
SMTP_SECURE="false"

